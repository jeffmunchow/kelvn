{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.anthropic.com https://*.r2.cloudflarestorage.com https://*.r2.dev; object-src 'none'; base-uri 'self';"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/galeria/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/galeria.html"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/kelvn.html"
    },
    {
      "src": "/assinar/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/assinar.html"
    },
    {
      "src": "/form",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/form.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/$1"
    }
  ]
}
