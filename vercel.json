{
  "crons": [
    {
      "path": "/api/newsletter-semanal",
      "schedule": "0 11 * * 1"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/galeria/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/galeria.html"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/kelvn.html"
    },
    {
      "src": "/assinar/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/assinar.html"
    },
    {
      "src": "/form",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/form.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/$1"
    }
  ]
}
