{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/kelvn.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/$1"
    }
  ]
}
