{
  "functions": {
    "api/contrato-pdf.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "node_modules/@sparticuz/chromium/bin/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/kelvn.html"
    },
    {
      "src": "/assinar/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/assinar.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/$1"
    }
  ]
}
