{
  "functions": {
    "api/album-exportar.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/meta-ads?action=sync",
      "schedule": "0 6 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "strict-origin-when-cross-origin",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=()",
        "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://cdn.jsdelivr.net https://*.r2.cloudflarestorage.com https://*.r2.dev https://cdn.jsdelivr.net; object-src 'none'; base-uri 'self'; frame-ancestors 'none';"
      },
      "continue": true
    },
    {
      "src": "/api/newsletter(.*)",
      "dest": "/api/album-revisao$1"
    },
    {
      "src": "/api/gallery-delete",
      "dest": "/api/gallery-ops?action=delete"
    },
    {
      "src": "/api/gallery-download",
      "dest": "/api/gallery-ops?action=download"
    },
    {
      "src": "/api/gallery-cover",
      "dest": "/api/gallery-ops?action=cover"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/album-revisao",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/album-revisao.html"
    },
    {
      "src": "/album.html",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/album.html"
    },
    {
      "src": "/galeria/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/galeria.html"
    },
    {
      "src": "/",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/kelvn.html"
    },
    {
      "src": "/assinar/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/assinar.html"
    },
    {
      "src": "/form",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/form.html"
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "app.kelvn.com.br" }],
      "dest": "/app/$1"
    }
  ]
}
